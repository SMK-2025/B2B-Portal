{
  "name": "b2b-dienstleistungsportal",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"pnpm --filter @portal/web dev\" \"pnpm --filter @portal/api dev\"",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3"
  }
}
